#!/usr/bin/env sh
# Refuse to commit under an identity this clone has not been configured to use.
# The repository sets core.hooksPath=.githooks, so this runs on every commit,
# including --amend. A commit made under the wrong author cannot be fixed by a
# follow-up commit, so the cheapest place to catch it is before it exists.
set -eu
cd "$(git rev-parse --show-toplevel)"
exec ./dev/authorcheck --staged
