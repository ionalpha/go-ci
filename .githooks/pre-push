#!/usr/bin/env sh
# Last check before anything leaves the machine.
#
# Two separate things have to be right, and they fail independently:
#
#   1. Every commit about to be pushed is authored by the pinned identity
#      (hooks.authorEmail). The pre-commit hook covers commits made here; this
#      covers the rest: a commit cherry-picked from elsewhere, one made before the
#      hooks were armed, or one rewritten by a rebase.
#
#   2. The push goes through the pinned SSH host (hooks.remoteHost), so it
#      authenticates as the right account. Git identity and SSH identity are
#      different: correctly-authored commits pushed over the wrong key are recorded
#      by GitHub as pushed, merged and deleted by that key's owner.
#
# The transport is checked first, because it is the one git itself will never
# complain about.
#
# stdin is one "<local ref> <local oid> <remote ref> <remote oid>" line per ref.
set -eu
cd "$(git rev-parse --show-toplevel)"

remote="${1:-origin}"
./dev/pushcheck "$remote"

zero_re='^0*$'

while read -r _local_ref local_oid _remote_ref remote_oid; do
  # An all-zero local oid means the ref is being deleted: no commits to check.
  case "$local_oid" in '') continue ;; esac
  if printf '%s' "$local_oid" | grep -Eq "$zero_re"; then
    continue
  fi

  if printf '%s' "$remote_oid" | grep -Eq "$zero_re"; then
    # New ref on the remote: check every commit it would add that the remote does
    # not already have on some other branch.
    ./dev/authorcheck --range "$local_oid" --not --remotes="$remote"
  else
    ./dev/authorcheck --range "$remote_oid..$local_oid"
  fi
done
